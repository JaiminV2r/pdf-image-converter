{
  "name": "pdf-image-converter",
  "version": "0.1.0",
  "description": "Convert PDF pages to images — zero runtime dependencies, works in Node.js and NestJS",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Jaimin Vaddoriya",
    "url": "https://github.com/JaiminV2r"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JaiminV2r/pdf-image-converter.git"
  },
  "bugs": {
    "url": "https://github.com/JaiminV2r/pdf-image-converter/issues"
  },
  "homepage": "https://github.com/JaiminV2r/pdf-image-converter#readme",
  "exports": {
    ".": {
      "types": "./dist/types/nodejs/index.d.ts",
      "import": "./dist/esm/nodejs/index.js",
      "require": "./dist/cjs/nodejs/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/types/nestjs/index.d.ts",
      "import": "./dist/esm/nestjs/index.js",
      "require": "./dist/cjs/nestjs/index.cjs"
    }
  },
  "main": "./dist/cjs/nodejs/index.cjs",
  "module": "./dist/esm/nodejs/index.js",
  "types": "./dist/types/nodejs/index.d.ts",
  "files": [
    "dist/",
    "vendor/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "vendor": "node scripts/vendor-wasm.mjs",
    "build": "npm run vendor && tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^20.0.0",
    "mupdf": "^1.4.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "pdf",
    "image",
    "converter",
    "pdf-to-image",
    "pdf-to-png",
    "pdf-to-jpeg",
    "nestjs",
    "nodejs",
    "zero-dependency",
    "pdf parser",
    "pdf renderer",
    "wasm pdf",
    "pdf processing"
  ]
}